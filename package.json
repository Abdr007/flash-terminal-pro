{
  "name": "flash-terminal-pro",
  "version": "0.1.0",
  "description": "Protocol-grade CLI for Flash.trade — perps, swaps, LP, strategies",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "flash": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.2",
    "chalk": "^5.4.1",
    "dotenv": "^16.4.7",
    "flash-sdk": "^15.9.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^22.13.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
