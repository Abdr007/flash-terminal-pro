# Flash-X Configuration
# Copy to .env and fill in values

# Solana RPC (required)
RPC_URL=https://api.mainnet-beta.solana.com
RPC_BACKUP_URL=

# Network: mainnet-beta | devnet
NETWORK=mainnet-beta

# Wallet keypair path (required for trading)
KEYPAIR_PATH=~/.config/solana/id.json

# Flash API
FLASH_API_URL=https://flashapi.trade

# Simulation mode (default: true — no real trades)
SIMULATION_MODE=true

# Risk limits
MAX_LEVERAGE=50
MAX_COLLATERAL_PER_TRADE=1000
MAX_POSITION_SIZE=50000
MAX_TOTAL_EXPOSURE=100000

# Trading safety
MAX_TRADES_PER_MINUTE=10
MIN_DELAY_BETWEEN_TRADES_MS=3000
DEFAULT_SLIPPAGE_BPS=80

# Compute budget
COMPUTE_UNIT_LIMIT=600000
COMPUTE_UNIT_PRICE=50000

# AI (optional — for fallback NLP)
GROQ_API_KEY=
